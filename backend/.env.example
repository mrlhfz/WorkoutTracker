# Port the API server listens on.
PORT=3001

# Comma-separated list of origins allowed by CORS.
# Leave unset to fall back to the built-in defaults (https://mrlhfz.github.io, http://localhost:5173).
# Set this when deploying to a new frontend host:
# ALLOWED_ORIGINS=https://mrlhfz.github.io,http://localhost:5173,https://your-new-frontend.example.com
ALLOWED_ORIGINS=
