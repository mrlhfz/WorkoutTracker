# Base URL the frontend uses for all API calls, including the /api suffix.
#
# Leave unset for local dev: requests fall back to the relative "/api" path,
# which the Vite dev server proxies to http://localhost:3001 (see vite.config.js).
#
# Set this when the frontend and backend are deployed to different origins
# (e.g. frontend on GitHub Pages, backend on Render/Railway):
# VITE_API_URL=https://your-backend-host.example.com/api
VITE_API_URL=
